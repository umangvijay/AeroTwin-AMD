# AeroTwin Edge - Environment Configuration Template
# Copy this file to .env and fill in your values

# Database Configuration
DATABASE_URL=sqlite:///./aerotwin_prod.db

# API Security (generate a strong key for production)
API_KEY=your_secure_api_key_here

# ML Configuration
ML_ANOMALY_INTERVAL=10
ML_MIN_SAMPLES=10
ML_CONTAMINATION=0.1

# Cloud Deployment Configuration
# Set CLOUD_MODE=true for cloud hosting
# Set SIMULATOR_ENABLED=true to run bundled simulator
CLOUD_MODE=true
SIMULATOR_ENABLED=true
SIMULATOR_INTERVAL=5.0
SIMULATOR_ZONE=Building-A-Floor-1
DEMO_SPIKE_INTERVAL=15

# Frontend Configuration (for dashboard.py)
# Set API_URL to your cloud backend URL when deploying
# Example: API_URL=https://aerotwin-backend.onrender.com
API_URL=http://localhost:8000
